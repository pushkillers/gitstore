# ============================================
# MODO MOCK - Frontend Standalone
# ============================================
# O frontend agora funciona sem backend
# Todas as configurações abaixo são opcionais

# Database (não usado no modo mock)
# POSTGRES_USER=gitstore
# POSTGRES_PASSWORD=gitstore123
# POSTGRES_DB=gitstore

# Cache (não usado no modo mock)
# REDIS_URL=redis://localhost:6379

# App
NODE_ENV=development
PORT=3000

# ============================================
# CONFIGURAÇÕES PARA MODO FULLSTACK (OPCIONAL)
# ============================================
# Descomente se quiser usar o backend Go

# Backend Go
# GO_PORT=3001
# JWT_SECRET=your_jwt_secret_here
# JWT_EXPIRATION=24h

# GitHub OAuth (não implementado no modo mock)
# GITHUB_CLIENT_ID=your_github_client_id
# GITHUB_CLIENT_SECRET=your_github_client_secret
# GITHUB_CALLBACK_URL=http://localhost:3001/auth/github/callback

# Google OAuth (não implementado no modo mock)
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# Frontend URL
# FRONTEND_URL=http://localhost:3000
# NEXT_PUBLIC_API_URL=http://localhost:3001
